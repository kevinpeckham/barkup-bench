{
	"name": "barkup-bench",
	"version": "0.0.1",
	"description": "Benchmark: HTML dialect + whole-tree rewrite (barkup) vs JSON + granular mutation tools for LLM agents editing typed trees.",
	"author": "Kevin Peckham",
	"license": "MIT",
	"type": "module",
	"private": true,
	"scripts": {
		"check": "tsc --noEmit",
		"format": "bunx biome format --write .",
		"lint": "bunx biome lint --write .",
		"test": "bun test",
		"corpus": "bun run scripts/generate-corpus.ts",
		"describe": "bun run scripts/describe-construction.ts",
		"pilot": "bun run scripts/run-pilot.ts",
		"matrix": "bun run scripts/run-matrix.ts",
		"prompts": "bun run scripts/render-prompts.ts",
		"report": "bun run scripts/report.ts"
	},
	"dependencies": {
		"@ai-sdk/gateway": "latest",
		"@kevinpeckham/barkup": "^0.2.0",
		"ai": "latest",
		"fast-json-patch": "^3.1.1",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@resvg/resvg-js": "^2.6.2",
		"@types/bun": "^1.3.14",
		"ajv": "^8.20.0",
		"fast-check": "^3.23.0",
		"linkedom": "^0.18.5",
		"typescript": "^5.7.0",
		"varlock": "^1.9.0"
	},
	"engines": {
		"node": ">=18"
	}
}
